# ===========================================
# KMP HORREN - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE
# ===========================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# STRIPE (Payments)
# ===========================================
# Get your API keys from Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# RESEND (Email)
# ===========================================
# Get your API key from Resend Dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=info@kmphorren.nl
ADMIN_EMAIL=info@kmphorren.nl

# ===========================================
# GOOGLE AI (Gemini) - Optional
# ===========================================
# Get your API key from Google AI Studio
GOOGLE_AI_API_KEY=AIzaSy...

# ===========================================
# APP
# ===========================================
NEXT_PUBLIC_APP_URL=https://kmp-horren.nl
